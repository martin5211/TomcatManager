{
  "name": "tomcat-manager",
  "displayName": "Tomcat Manager for VS Code",
  "description": "Manage multiple Tomcat servers with per-project configuration overrides",
  "version": "0.2.0",
  "publisher": "MartinCaminoa",
  "repository": {
    "type": "git",
    "url": "https://github.com/martin5211/TomcatManager"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tomcatManager.deploy",
        "title": "Tomcat: Deploy"
      },
      {
        "command": "tomcatManager.clean",
        "title": "Tomcat: Clean"
      },
      {
        "command": "tomcatManager.run",
        "title": "Tomcat: Run"
      },
      {
        "command": "tomcatManager.stop",
        "title": "Tomcat: Stop"
      },
      {
        "command": "tomcatManager.restart",
        "title": "Tomcat: Restart"
      },
      {
        "command": "tomcatManager.configureServers",
        "title": "Tomcat: Configure Servers"
      }
    ],
    "configuration": {
      "title": "Tomcat Manager",
      "properties": {
        "tomcatManager.servers": {
          "type": "array",
          "default": [],
          "description": "List of available Tomcat server installations",
          "items": {
            "type": "object",
            "required": ["id", "name", "tomcatHome", "jdkHome"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this server"
              },
              "name": {
                "type": "string",
                "description": "Human-readable display name"
              },
              "tomcatHome": {
                "type": "string",
                "description": "Path to Tomcat installation directory (CATALINA_HOME)"
              },
              "jdkHome": {
                "type": "string",
                "description": "Path to JDK installation (JAVA_HOME). Must point to a JDK, not a JRE."
              },
              "startupScript": {
                "type": "string",
                "description": "Custom startup script path (defaults to bin/startup.sh or bin/startup.bat)"
              },
              "shutdownScript": {
                "type": "string",
                "description": "Custom shutdown script path (defaults to bin/shutdown.sh or bin/shutdown.bat)"
              },
              "defaultCatalinaOpts": {
                "type": "string",
                "description": "Default CATALINA_OPTS for this server"
              },
              "defaultJavaOpts": {
                "type": "string",
                "description": "Default JAVA_OPTS for this server"
              }
            },
            "additionalProperties": false
          }
        },
        "tomcatManager.projects": {
          "type": "object",
          "default": {},
          "description": "Per-project configuration overrides keyed by workspace folder name",
          "additionalProperties": {
            "type": "object",
            "required": ["serverId"],
            "properties": {
              "serverId": {
                "type": "string",
                "description": "ID of the server to use for this project"
              },
              "catalinaOpts": {
                "type": "string",
                "description": "Override CATALINA_OPTS for this project"
              },
              "javaOpts": {
                "type": "string",
                "description": "Override JAVA_OPTS for this project"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
