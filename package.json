{
  "name": "tomcat-manager",
  "displayName": "Tomcat Manager for VS Code",
  "description": "Manage multiple Tomcat servers with per-project configuration overrides",
  "version": "0.3.1",
  "publisher": "MartinCaminoa",
  "repository": {
    "type": "git",
    "url": "https://github.com/martin5211/TomcatManager"
  },
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onDebugResolve:tomcat",
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tomcatManager.deploy",
        "title": "Tomcat: Deploy"
      },
      {
        "command": "tomcatManager.clean",
        "title": "Tomcat: Clean"
      },
      {
        "command": "tomcatManager.run",
        "title": "Tomcat: Run"
      },
      {
        "command": "tomcatManager.stop",
        "title": "Tomcat: Stop"
      },
      {
        "command": "tomcatManager.restart",
        "title": "Tomcat: Restart"
      },
      {
        "command": "tomcatManager.configureServers",
        "title": "Tomcat: Configure Servers"
      }
    ],
    "debuggers": [
      {
        "type": "tomcat",
        "label": "Tomcat",
        "initialConfigurations": [
          {
            "type": "tomcat",
            "request": "launch",
            "name": "Run Tomcat"
          }
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "serverId": {
                "type": "string",
                "description": "Server ID from tomcatManager.servers (omit to auto-resolve)"
              },
              "jpda": {
                "type": "boolean",
                "default": false,
                "description": "Enable JPDA debugging"
              },
              "jpdaPort": {
                "type": "number",
                "default": 8000,
                "description": "JPDA debug port"
              },
              "jpdaSuspend": {
                "type": "boolean",
                "default": false,
                "description": "Suspend JVM until debugger attaches"
              },
              "attachJavaDebugger": {
                "type": "boolean",
                "default": true,
                "description": "Auto-attach VS Code Java debugger after JPDA start"
              },
              "attachDelay": {
                "type": "number",
                "default": 3000,
                "description": "Milliseconds to wait before attaching Java debugger"
              },
              "catalinaOpts": {
                "type": "string",
                "description": "CATALINA_OPTS for this project (appended to server defaults)"
              },
              "javaOpts": {
                "type": "string",
                "description": "JAVA_OPTS for this project (appended to server defaults)"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Tomcat: Run Server",
            "description": "Start a Tomcat server",
            "body": {
              "type": "tomcat",
              "request": "launch",
              "name": "${1:Run Tomcat}"
            }
          },
          {
            "label": "Tomcat: Debug (JPDA)",
            "description": "Start Tomcat with JPDA debugging",
            "body": {
              "type": "tomcat",
              "request": "launch",
              "name": "${1:Debug Tomcat}",
              "jpda": true,
              "jpdaPort": "^8000"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Tomcat Manager",
      "properties": {
        "tomcatManager.servers": {
          "type": "array",
          "default": [],
          "description": "List of available Tomcat server installations",
          "items": {
            "type": "object",
            "required": ["id", "name", "tomcatHome", "jdkHome"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this server"
              },
              "name": {
                "type": "string",
                "description": "Human-readable display name"
              },
              "tomcatHome": {
                "type": "string",
                "description": "Path to Tomcat installation directory (CATALINA_HOME)"
              },
              "jdkHome": {
                "type": "string",
                "description": "Path to JDK installation (JAVA_HOME). Must point to a JDK, not a JRE."
              },
              "startupScript": {
                "type": "string",
                "description": "Custom startup script path (defaults to bin/startup.sh or bin/startup.bat)"
              },
              "shutdownScript": {
                "type": "string",
                "description": "Custom shutdown script path (defaults to bin/shutdown.sh or bin/shutdown.bat)"
              },
              "defaultCatalinaOpts": {
                "type": "string",
                "description": "Default CATALINA_OPTS for this server"
              },
              "defaultJavaOpts": {
                "type": "string",
                "description": "Default JAVA_OPTS for this server"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "scripts": {
    "test": "jest",
    "compile": "tsc -p ./ && vsce package",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
